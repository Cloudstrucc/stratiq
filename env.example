# ─────────────────────────────────────────────────────────────────────────────
#  STRATIQ — Environment Variables
#
#  LOCAL DEV : copy this file to .env and fill in values
#  AZURE     : set each key in App Service → Configuration → App Settings
#              (do NOT deploy this file — it is in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_URL=https://stratiq-e2a79c.azurewebsites.net

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# IMPORTANT: set this in Azure App Settings — never commit the real value
SESSION_SECRET=replace_with_64_char_random_hex_string

# ── Database (SQLite) ─────────────────────────────────────────────────────────
# Azure: /home is the only persisted mount — use /home/db
# Local: leave as ./db  (relative to project root)
DB_DIR=/home/db
DB_PATH=/home/db/stratiq.db

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# Rotate your key at https://console.anthropic.com — never commit real keys
ANTHROPIC_API_KEY=replace_with_your_anthropic_api_key

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Production: use SendGrid, Mailgun, or Azure Communication Services
# Dev/test:   use Mailtrap (https://mailtrap.io)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_or_sendgrid_user
SMTP_PASS=your_mailtrap_or_sendgrid_password
EMAIL_FROM=noreply@stratiq.io
EMAIL_FROM_NAME=Stratiq

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
# Authorised redirect URI: https://stratiq-e2a79c.azurewebsites.net/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://stratiq-e2a79c.azurewebsites.net/auth/google/callback

# ── Market Data (optional) ────────────────────────────────────────────────────
# Alpha Vantage free tier: https://www.alphavantage.co/support/#api-key
# Leave blank to use mock/cached data in development
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ── Admin seed defaults ───────────────────────────────────────────────────────
# Only used during: npm run seed
# Change the admin password immediately after first login
ADMIN_EMAIL=admin@stratiq.io
ADMIN_PASSWORD=Admin@Stratiq2025!

# ── Azure build (set in App Service App Settings, not here) ──────────────────
# SCM_DO_BUILD_DURING_DEPLOYMENT=true
