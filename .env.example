# ─────────────────────────────────────────────
#  STRATIQ — Environment Variables
#  Copy this file to .env and fill in values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
SESSION_SECRET=replace_with_a_long_random_string_minimum_32_chars

# Database (SQLite — path relative to project root)
DB_PATH=./db/stratiq.db

# ─── Anthropic AI ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email / SMTP ────────────────────────────
# For development you can use Mailtrap (https://mailtrap.io)
# For production use SendGrid, Mailgun, or your SMTP server
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
EMAIL_FROM=noreply@stratiq.io
EMAIL_FROM_NAME=Stratiq

# ─── Google OAuth (optional) ─────────────────
# Create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── Market Data (optional) ──────────────────
# Alpha Vantage free tier: https://www.alphavantage.co/support/#api-key
# Leave blank to use mock/cached data in development
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ─── Admin Defaults ───────────────────────────
# These are only used during initial DB seed (npm run seed)
# Change the password immediately after first login!
ADMIN_EMAIL=admin@stratiq.io
ADMIN_PASSWORD=Admin@Stratiq2025!
