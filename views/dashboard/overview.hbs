{{!-- Stats Row --}}
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="lbl">Portfolio Value</div>
      <div class="val">${{formatNumber valueData.totalValue}}</div>
      <div class="sub {{#gt valueData.totalPnL 0}}up{{else}}dn{{/gt}}">
        {{#gt valueData.totalPnL 0}}▲{{else}}▼{{/gt}}
        ${{formatNumber valueData.totalPnL}} ({{formatPct valueData.totalPnLPct}}%)
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="lbl">Today's P&L</div>
      <div class="val {{#gt report.daily_pnl 0}}text-accent{{else}}text-red{{/gt}}">
        {{#gt report.daily_pnl 0}}+{{/gt}}${{formatNumber report.daily_pnl}}
      </div>
      <div class="sub {{#gt report.daily_pnl 0}}up{{else}}dn{{/gt}}">
        {{formatPct report.daily_pnl_pct}}%
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="lbl">Cash Available</div>
      <div class="val">${{formatNumber portfolio.cash_balance}}</div>
      <div class="sub" style="color:var(--text-muted);">
        {{cashPct portfolio.cash_balance portfolio.initial_budget}}% of budget
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="lbl">Positions</div>
      <div class="val">{{positions.length}}</div>
      <div class="sub" style="color:var(--text-muted);">{{portfolio.strategy_key}} strategy</div>
    </div>
  </div>
</div>

{{!-- Charts --}}
<div class="row g-3 mb-4">
  <div class="col-lg-8">
    <div class="chart-wrap">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="chart-title">Portfolio Performance</div>
        <div class="d-flex gap-1">
          <span class="dash-tab active">1M</span>
          <span class="dash-tab">3M</span>
          <span class="dash-tab">YTD</span>
        </div>
      </div>
      <canvas id="perfChart" height="180"></canvas>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="chart-wrap h-100">
      <div class="chart-title mb-2">Allocation</div>
      <canvas id="allocChart" height="180"></canvas>
    </div>
  </div>
</div>

{{!-- AI Daily Summary --}}
{{#if report}}
<div class="chart-wrap mb-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="chart-title">🤖 Today's AI Summary</div>
    <span class="pill-tag" style="font-size:.72rem;">{{report.report_date}}</span>
  </div>
  <div class="ai-msg">
    <div class="role ai"><i class="bi bi-stars"></i> Stratiq AI · {{portfolio.strategy_key}} advisor</div>
    <div class="body">{{report.ai_summary}}</div>
  </div>
  <div class="d-flex gap-2 flex-wrap mt-2">
    <span class="pill-tag"><i class="bi bi-shield-check text-accent"></i> {{positions.length}} positions</span>
    <span class="pill-tag"><i class="bi bi-arrow-repeat"></i> {{report.total_trades}} trade(s) today</span>
    {{#if report.email_sent}}<span class="pill-tag"><i class="bi bi-envelope-check"></i> Report sent</span>{{/if}}
  </div>
</div>
{{/if}}

{{!-- Holdings table --}}
<div class="chart-wrap">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="chart-title">Top Holdings</div>
    <a href="/dashboard/portfolio" style="font-size:.82rem;color:var(--accent);text-decoration:none;">View all →</a>
  </div>
  {{#if positions.length}}
  <div style="overflow-x:auto;">
    <table class="s-table">
      <thead>
        <tr><th>Symbol</th><th>Name</th><th>Shares</th><th>Price</th><th>Value</th><th>P&L</th></tr>
      </thead>
      <tbody>
        {{#each positions}}
        <tr>
          <td><strong>{{symbol}}</strong></td>
          <td style="color:var(--text-muted);">{{name}}</td>
          <td>{{shares}}</td>
          <td>${{formatDecimal current_price}}</td>
          <td>${{formatNumber (multiply shares current_price)}}</td>
          <td class="{{#gt current_price avg_cost}}text-accent{{else}}text-red{{/gt}}">
            {{#gt current_price avg_cost}}+{{/gt}}${{formatNumber (subtract (multiply shares current_price) (multiply shares avg_cost))}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state">
    <i class="bi bi-briefcase"></i>
    <p>No positions yet. <a href="/dashboard/portfolio">Add your first position</a> or <a href="/dashboard/ai-strategy">let AI build your portfolio</a>.</p>
  </div>
  {{/if}}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const gridC  = isDark ? 'rgba(255,255,255,.05)' : 'rgba(0,0,0,.06)';
    const textC  = isDark ? '#7c8ba1' : '#5a6580';

    // Performance chart
    new Chart(document.getElementById('perfChart'), {
      type:'line',
      data:{
        labels:['Jun 1','Jun 3','Jun 5','Jun 7','Jun 9','Jun 11','Jun 14'],
        datasets:[
          {label:'Portfolio',data:[105000,108200,107400,112000,118400,122800,{{valueData.totalValue}}],
           borderColor:'#22c55e',fill:true,backgroundColor:'rgba(34,197,94,.06)',tension:.45,pointRadius:0,borderWidth:2.5},
          {label:'S&P 500',data:[100000,100800,100200,101500,103200,106000,108100],
           borderColor:'rgba(59,130,246,.5)',fill:false,tension:.45,pointRadius:0,borderWidth:1.5,borderDash:[4,4]},
        ]
      },
      options:{
        plugins:{legend:{labels:{color:textC,boxWidth:10,font:{size:11}}}},
        scales:{
          x:{grid:{color:gridC},ticks:{color:textC,font:{size:10}}},
          y:{grid:{color:gridC},ticks:{color:textC,font:{size:10},callback:v=>'$'+(v/1000).toFixed(0)+'k'}},
        },
        responsive:true,maintainAspectRatio:true,
      }
    });

    // Allocation donut
    const allocCtx = document.getElementById('allocChart');
    {{#if positions.length}}
    new Chart(allocCtx, {
      type:'doughnut',
      data:{
        labels: [{{#each positions}}'{{symbol}}'{{#unless @last}},{{/unless}}{{/each}}],
        datasets:[{
          data: [{{#each positions}}{{multiply shares current_price}}{{#unless @last}},{{/unless}}{{/each}}],
          backgroundColor:['#22c55e','#3b82f6','#8b5cf6','#ef4444','#f59e0b','#06b6d4','#64748b','#a855f7','#10b981','#f97316'],
          borderWidth:0,hoverOffset:4,
        }]
      },
      options:{
        plugins:{legend:{position:'right',labels:{color:textC,boxWidth:9,font:{size:10}}}},
        cutout:'62%',responsive:true,maintainAspectRatio:true,
      }
    });
    {{/if}}
  });
</script>
