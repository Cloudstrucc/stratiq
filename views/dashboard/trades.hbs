<div class="chart-wrap">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div class="chart-title">Trade History</div>
    <div class="d-flex gap-2">
      <span class="pill-tag">{{trades.length}} trades</span>
    </div>
  </div>

  {{#if trades.length}}
  <div style="overflow-x:auto;">
    <table class="s-table">
      <thead>
        <tr><th>Date</th><th>Type</th><th>Symbol</th><th>Shares</th><th>Price</th><th>Total</th><th>Source</th><th>Reason</th></tr>
      </thead>
      <tbody>
        {{#each trades}}
        <tr>
          <td style="color:var(--text-muted);font-size:.82rem;white-space:nowrap;">{{formatDate executed_at}}</td>
          <td>
            <span class="risk-badge {{#eq trade_type 'buy'}}risk-low{{/eq}}{{#eq trade_type 'sell'}}risk-high{{/eq}}{{#eq trade_type 'hold'}}risk-med{{/eq}}" style="font-size:.72rem;">
              {{trade_type}}
            </span>
          </td>
          <td><strong>{{symbol}}</strong></td>
          <td>{{formatDecimal shares}}</td>
          <td>${{formatDecimal price}}</td>
          <td>${{formatNumber total_value}}</td>
          <td>
            {{#if ai_generated}}
              <span class="pill-tag" style="font-size:.7rem;"><i class="bi bi-robot"></i> AI</span>
            {{else}}
              <span class="pill-tag" style="font-size:.7rem;">Manual</span>
            {{/if}}
          </td>
          <td style="color:var(--text-muted);font-size:.8rem;max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{reason}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state">
    <i class="bi bi-arrow-left-right"></i>
    <p>No trades yet. <a href="/dashboard/portfolio">Add your first position</a> or enable AI auto-trading.</p>
  </div>
  {{/if}}
</div>
