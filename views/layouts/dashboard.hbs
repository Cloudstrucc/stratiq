<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{title}}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/stratiq.css"/>
</head>
<body class="dash-body">

  <!-- Flash messages -->
  {{#if flashError.length}}
    <div class="flash-toast flash-error">
      <i class="bi bi-exclamation-circle-fill"></i> {{flashError.[0]}}
    </div>
  {{/if}}
  {{#if flashSuccess.length}}
    <div class="flash-toast flash-success">
      <i class="bi bi-check-circle-fill"></i> {{flashSuccess.[0]}}
    </div>
  {{/if}}

  <!-- Mobile nav bar -->
  <div class="mobile-topbar d-md-none">
    <a class="brand" href="/dashboard">Strat<span>iq</span></a>
    <div class="d-flex gap-2">
      <div class="theme-btn" onclick="toggleTheme()"><i class="bi bi-moon-fill" id="themeIconM"></i></div>
      <button class="theme-btn border-0" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
    </div>
  </div>

  <!-- Sidebar -->
  <aside class="dash-sidebar" id="sidebar">
    <div class="side-brand d-none d-md-block">Strat<span>iq</span></div>

    <nav class="side-nav">
      <a class="side-link {{#eq tab 'overview'}}active{{/eq}}" href="/dashboard">
        <i class="bi bi-grid-1x2"></i><span>Overview</span>
      </a>
      <a class="side-link {{#eq tab 'portfolio'}}active{{/eq}}" href="/dashboard/portfolio">
        <i class="bi bi-briefcase"></i><span>Portfolio</span>
      </a>
      <a class="side-link {{#eq tab 'ai-strategy'}}active{{/eq}}" href="/dashboard/ai-strategy">
        <i class="bi bi-robot"></i><span>AI Strategy</span>
      </a>
      <a class="side-link {{#eq tab 'trades'}}active{{/eq}}" href="/dashboard/trades">
        <i class="bi bi-arrow-left-right"></i><span>Trades</span>
      </a>
      <a class="side-link {{#eq tab 'reports'}}active{{/eq}}" href="/dashboard/reports">
        <i class="bi bi-envelope-paper"></i><span>Reports</span>
      </a>

      <div class="side-divider"></div>

      <a class="side-link {{#eq tab 'settings'}}active{{/eq}}" href="/dashboard/settings">
        <i class="bi bi-gear"></i><span>Settings</span>
      </a>

      {{#if isAdmin}}
      <a class="side-link {{#eq tab 'admin'}}active{{/eq}}" href="/admin">
        <i class="bi bi-shield-lock"></i><span>Admin</span>
      </a>
      {{/if}}

      <div class="side-divider"></div>

      <a class="side-link" href="/auth/logout" style="color:var(--red);">
        <i class="bi bi-box-arrow-left"></i><span>Sign Out</span>
      </a>
    </nav>

    <!-- User pill at bottom -->
    <div class="side-user">
      <div class="side-user-avatar">{{user.first_name.[0]}}{{user.last_name.[0]}}</div>
      <div class="side-user-info">
        <div class="side-user-name">{{user.first_name}} {{user.last_name}}</div>
        <div class="side-user-plan">{{user.plan}} plan</div>
      </div>
    </div>
  </aside>

  <!-- Main content -->
  <main class="dash-content">
    <!-- Top bar -->
    <div class="dash-topbar">
      <div>
        <h1 class="dash-page-title">{{title}}</h1>
      </div>
      <div class="d-flex align-items-center gap-2">
        <div class="theme-btn d-none d-md-flex" onclick="toggleTheme()">
          <i class="bi bi-moon-fill" id="themeIcon"></i>
        </div>
        <div class="user-badge">
          <div class="user-avatar">{{user.first_name.[0]}}</div>
          <span class="d-none d-lg-inline">{{user.first_name}}</span>
        </div>
      </div>
    </div>

    {{{body}}}
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="/js/theme.js"></script>
  <script src="/js/dashboard.js"></script>
  <script>
    setTimeout(() => {
      document.querySelectorAll('.flash-toast').forEach(el => {
        el.style.opacity = '0';
        setTimeout(() => el.remove(), 400);
      });
    }, 4000);
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
    }
  </script>
</body>
</html>
