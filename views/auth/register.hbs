<div class="auth-wrap">
  <div class="auth-card" style="max-width:480px;">
    <a href="/" class="auth-brand">Strat<span>iq</span></a>
    <h2>Create your account</h2>
    <p>Set up your investment simulation in 60 seconds</p>

    <form action="/auth/register" method="POST">
      <div class="row g-2 mb-2">
        <div class="col-6">
          <label class="s-label">First Name</label>
          <input class="s-input" type="text" name="first_name" placeholder="Alex" required/>
        </div>
        <div class="col-6">
          <label class="s-label">Last Name</label>
          <input class="s-input" type="text" name="last_name" placeholder="Chen" required/>
        </div>
      </div>
      <div class="s-input-group">
        <label class="s-label">Email</label>
        <input class="s-input" type="email" name="email" placeholder="you@example.com" required autocomplete="email"/>
      </div>
      <div class="s-input-group">
        <label class="s-label">Password</label>
        <input class="s-input" type="password" name="password" placeholder="Min. 8 characters" required autocomplete="new-password"/>
      </div>
      <div class="s-input-group">
        <label class="s-label">Starting Budget (Simulated)</label>
        <select class="s-input" name="sim_budget">
          <option value="10000">$10,000</option>
          <option value="50000" selected>$50,000</option>
          <option value="100000">$100,000</option>
          <option value="500000">$500,000</option>
        </select>
      </div>
      <div class="s-input-group">
        <label class="s-label">Initial Strategy</label>
        <select class="s-input" name="strategy_key">
          <option value="manual">I'll build my own portfolio</option>
          <option value="buffett">Warren Buffett — Value Investing</option>
          <option value="dalio">Ray Dalio — All Weather</option>
          <option value="dca_index">DCA Index — S&P 500</option>
          <option value="lynch">Peter Lynch — GARP</option>
        </select>
      </div>
      <button type="submit" class="s-btn-full">Create Account &amp; Start Simulating</button>
      <p class="text-center mt-3" style="font-size:.78rem;color:var(--text-dim);">
        By signing up you agree to our <a href="#" style="color:var(--accent);">Terms</a> &amp; <a href="#" style="color:var(--accent);">Privacy Policy</a>
      </p>
    </form>

    <p class="text-center mt-2" style="font-size:.85rem;color:var(--text-muted);">
      Have an account? <a href="/auth/login" style="color:var(--accent);">Sign in</a>
    </p>
  </div>
</div>
