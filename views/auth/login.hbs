<div class="auth-wrap">
  <div class="auth-card">
    <a href="/" class="auth-brand">Strat<span>iq</span></a>
    <h2>Welcome back</h2>
    <p>Sign in to your simulation portfolio</p>

    <form action="/auth/login" method="POST">
      <div class="s-input-group">
        <label class="s-label">Email</label>
        <input class="s-input" type="email" name="email" placeholder="you@example.com" required autocomplete="email"/>
      </div>
      <div class="s-input-group">
        <label class="s-label">Password</label>
        <input class="s-input" type="password" name="password" placeholder="••••••••" required autocomplete="current-password"/>
      </div>
      <div class="d-flex justify-content-between align-items-center mb-3" style="font-size:.82rem;">
        <label style="display:flex;gap:8px;align-items:center;color:var(--text-muted);cursor:pointer;">
          <input type="checkbox" name="remember" style="accent-color:var(--accent);"/> Remember me
        </label>
        <a href="#" style="color:var(--accent);text-decoration:none;">Forgot password?</a>
      </div>
      <button type="submit" class="s-btn-full">Sign In</button>
    </form>

    {{#if GOOGLE_ENABLED}}
    <div class="divider">or</div>
    <a href="/auth/google" class="s-btn-full" style="background:var(--bg-input);color:var(--text);border:1px solid var(--border);text-decoration:none;display:block;text-align:center;">
      <i class="bi bi-google me-2"></i> Continue with Google
    </a>
    {{/if}}

    <p class="text-center mt-4" style="font-size:.85rem;color:var(--text-muted);">
      No account? <a href="/auth/register" style="color:var(--accent);">Sign up free</a>
    </p>
  </div>
</div>
