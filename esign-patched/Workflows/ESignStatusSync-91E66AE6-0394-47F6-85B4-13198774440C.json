                                                            "connectionName": "shared_commondataserviceforapps",
                                                            "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                                                            "operationId": "UpdateOnlyRecord"
                                                        },
                                                        "parameters": {
                                                            "entityName": "cs_signers",
                                                            "recordId": "@{first(outputs('Get_Signer_Record')?['body/value'])?['cs_signerid']}",
                                                            "item/statecode": 0,
                                                            "item/statuscode": 2,
                                                            "item/cs_signeddate": "@{items('Update_Signers_Status')?['signedDate']}",
                                                            "item/cs_vieweddate": "@{items('Update_Signers_Status')?['viewedDate']}",
                                                            "item/cs_declinedreason": "@{items('Update_Signers_Status')?['declineReason']}"
