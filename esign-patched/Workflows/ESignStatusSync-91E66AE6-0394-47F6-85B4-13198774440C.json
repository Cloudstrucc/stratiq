                            "type": "Foreach",
                            "foreach": "@body('HTTP_Get_Signers_Status')?['result']?['signers']",
                            "actions": {
                                "Get_Signer_Record": {
                                    "type": "OpenApiConnection",
                                    "inputs": {
                                        "host": {
                                            "connectionName": "shared_commondataserviceforapps",
                                            "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                                            "operationId": "GetItems"
                                        },
                                        "parameters": {
                                            "entityName": "cs_signers",
                                            "$filter": "@{concat('cs_envelopesignerid eq ', items('Update_Signers_Status')?['signerID'])}"
                                        },
                                        "authentication": "@parameters('$authentication')"
                                    },
                                    "runAfter": {}
                                },
                                "Switch_Signer_Status": {
                                    "type": "Switch",
                                    "expression": "@items('Update_Signers_Status')?['status']",
                                    "cases": {
                                        "Case_Pending": {
                                            "case": "Pending",
                                            "actions": {
                                                "Update_Signer_Pending": {
                                                    "type": "OpenApiConnection",
                                                    "inputs": {
                                                        "host": {
                                                            "connectionName": "shared_commondataserviceforapps",
                                                            "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                                                            "operationId": "UpdateOnlyRecord"
                                                        },
                                                        "parameters": {
                                                            "entityName": "cs_signers",
                                                            "recordId": "@{first(outputs('Get_Signer_Record')?['body/value'])?['cs_signerid']}",
                                                            "item/statecode": 0,
                                                            "item/statuscode": 1,
                                                            "item/cs_signeddate": "@{items('Update_Signers_Status')?['signedDate']}",
                                                            "item/cs_vieweddate": "@{items('Update_Signers_Status')?['viewedDate']}",
                                                            "item/cs_declinedreason": "@{items('Update_Signers_Status')?['declineReason']}"
                                                        },
                                                        "authentication": "@parameters('$authentication')"
                                                    },
                                                    "runAfter": {}
                                                }
                                            }
                                        },
                                        "Case_Viewed": {
                                            "case": "Viewed",
                                            "actions": {
                                                "Update_Signer_Viewed": {
                                                    "type": "OpenApiConnection",
