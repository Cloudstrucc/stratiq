                            "runAfter": {
                                "Switch_Envelope_Status": [
                                    "Succeeded"
                                ]
                            }
                        },
                        "Switch_Envelope_Status": {
                            "type": "Switch",
                            "expression": "@body('HTTP_Get_Envelope_Status')?['result']?['status']",
                            "cases": {
                                "Case_Completed": {
                                    "case": "Completed",
