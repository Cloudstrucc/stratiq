                    "type": "Foreach",
                    "foreach": "@outputs('Get_InProcess_Envelopes')?['body/value']",
                    "actions": {
                        "HTTP_Get_Envelope_Status": {
                            "type": "Http",
                            "inputs": {
                                "method": "GET",
                                "uri": "@{concat('https://ca1.assuresign.net/api/documentnow/v3.7/envelopes/', items('Process_Each_Envelope')?['cs_envelopeid'], '/status')}",
